# AILIZA Konfiguration — Kopie als .env und Keys eintragen

# LLM aktivieren (false = Basis-Modus ohne externe KI)
AILIZA_EXTERNAL_LLM_ENABLED=false

# LLM-Anbieter und Modell
AILIZA_LLM_PROVIDER=groq
AILIZA_LLM_MODEL=llama-3.3-70b-versatile

# API-Keys (nur einen benoetigt)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=

# Tavily Web-Suche (optional)
TAVILY_API_KEY=
