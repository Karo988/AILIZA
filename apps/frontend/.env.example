# AILIZA Frontend – Umgebungsvariablen
# Kopiere diese Datei zu .env.local für lokale Entwicklung.
# .env.local wird NICHT eingecheckt (siehe .gitignore).

# Backend-URL (Standard: lokaler Entwicklungsserver)
VITE_API_URL=http://localhost:8001

# Technische Fehlerdiagnose im UI anzeigen.
# NIEMALS auf true setzen in Produktion oder für echte Nutzer.
# Nur für lokale Entwicklung und Debugging.
VITE_DEBUG_ERRORS=false
