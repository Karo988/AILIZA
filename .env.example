# AILIZA Konfiguration
# Kopiere diese Datei zu .env und fuelle die Werte aus.
# NIEMALS .env in Git committen! NIEMALS echte Keys hier eintragen!

# ── Kill-Switch (externe KI) ───────────────────────────────────────────────
# Fail-closed: Standard false. Externe LLM-Calls nur wenn true.
AILIZA_EXTERNAL_LLM_ENABLED=false

# ── Mandanten ───────────────────────────────────────────────────────────────
AILIZA_DEFAULT_TENANT_ID=default

# ── KI-Modell / Provider (Keys leer lassen) ─────────────────────────────────
AILIZA_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Datenbank ────────────────────────────────────────────────────────────────
AILIZA_DATABASE_URL=sqlite:///./audit_log.db

# ── Retention (Tage) ─────────────────────────────────────────────────────────
AILIZA_DATA_RETENTION_DAYS=90
AILIZA_PERFORMANCE_LOG_RETENTION_DAYS=90
AILIZA_SECURITY_LOG_RETENTION_DAYS=365
AILIZA_COST_LOG_RETENTION_DAYS=365
AILIZA_DOCUMENT_RETENTION_DAYS=30
AILIZA_REFLECTION_TTL_DAYS=90

# ── DSGVO / EU AI Act ────────────────────────────────────────────────────────
AILIZA_PSEUDONYMIZE_USERS=true
AILIZA_HUMAN_OVERSIGHT=true
AILIZA_TRANSPARENCY_LANGUAGE=de

# ── CORS ──────────────────────────────────────────────────────────────────────
# In Produktion einschraenken! Kommaseparierte Origins.
# Leer lassen = "*" (nur fuer lokale Entwicklung)
AILIZA_CORS_ORIGINS=

# ── Suche ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
AILIZA_HOST=0.0.0.0
AILIZA_PORT=8001
AILIZA_DEBUG=false

# ── Sicherheit ────────────────────────────────────────────────────────────────
# AILIZA_SECRET_KEY: Starkes zufaelliges Secret (min. 32 Zeichen). Nie commiten!
AILIZA_SECRET_KEY=
AILIZA_JWT_EXPIRY_MINUTES=60

# ── Wartung ───────────────────────────────────────────────────────────────────
# Wie oft der automatische Retention-Cleanup laeuft (Stunden, Default 24)
AILIZA_CLEANUP_INTERVAL_HOURS=24

# ── Messenger / Telegram ─────────────────────────────────────────────────────
# Bot-Token von @BotFather. Leer lassen wenn Telegram nicht genutzt wird.
AILIZA_TELEGRAM_BOT_TOKEN=
# Optionaler Webhook-Secret (empfohlen fuer Produktionsbetrieb)
AILIZA_TELEGRAM_WEBHOOK_SECRET=
# Max. Nachrichten pro Nutzer pro Minute (Default 10)
AILIZA_TELEGRAM_RATE_LIMIT=10

# ── Bootstrap-Sperre ─────────────────────────────────────────────────────────
# Nach create_admin.py auf true setzen — sperrt erneutes Ausfuehren des Scripts
AILIZA_SETUP_DONE=
