# AILIZA Konfiguration
# Kopiere diese Datei zu .env und fuelle die Werte aus.
# NIEMALS .env in Git committen! NIEMALS echte Keys hier eintragen!

# ── Kill-Switch (externe KI) ───────────────────────────────────────────────
# Fail-closed: Standard false. Externe LLM-Calls nur wenn true.
AILIZA_EXTERNAL_LLM_ENABLED=false

# ── Mandanten ───────────────────────────────────────────────────────────────
AILIZA_DEFAULT_TENANT_ID=default

# ── KI-Modell / Provider (Keys leer lassen) ─────────────────────────────────
AILIZA_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Datenbank ────────────────────────────────────────────────────────────────
# WICHTIG: Immer absoluten Pfad verwenden (4 Slashes bei Linux/macOS)!
# Relativer Pfad erzeugt je nach Startverzeichnis unterschiedliche DB-Dateien.
#
# Linux/macOS:
# AILIZA_DATABASE_URL=sqlite:////home/user/AILIZA/data/ailiza.db
#
# Windows:
# AILIZA_DATABASE_URL=sqlite:///C:/AILIZA/data/ailiza.db
#
# Wenn nicht gesetzt: Dev-Fallback auf <repo-root>/data/ailiza_dev.db (mit Warnung).
AILIZA_DATABASE_URL=sqlite:////ABSOLUTER/PFAD/ZU/AILIZA/data/ailiza.db

# ── Retention (Tage) ─────────────────────────────────────────────────────────
AILIZA_DATA_RETENTION_DAYS=90
AILIZA_PERFORMANCE_LOG_RETENTION_DAYS=90
AILIZA_SECURITY_LOG_RETENTION_DAYS=365
AILIZA_COST_LOG_RETENTION_DAYS=365
AILIZA_DOCUMENT_RETENTION_DAYS=30
AILIZA_REFLECTION_TTL_DAYS=90

# ── DSGVO / EU AI Act ────────────────────────────────────────────────────────
AILIZA_PSEUDONYMIZE_USERS=true
AILIZA_HUMAN_OVERSIGHT=true
AILIZA_TRANSPARENCY_LANGUAGE=de

# ── CORS ──────────────────────────────────────────────────────────────────────
# In Produktion PFLICHT: konkrete Origin(s) setzen, niemals Wildcard!
# Beispiel: AILIZA_CORS_ORIGINS=https://ailiza-frontend.onrender.com
# Mehrere Origins: AILIZA_CORS_ORIGINS=https://ailiza.example.com,https://www.ailiza.example.com
# Leer lassen = "*" (nur fuer lokale Entwicklung, AILIZA_DEBUG=true setzen)
AILIZA_CORS_ORIGINS=

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
# AILIZA_FORCE_HTTPS=true aktiviert HTTP->HTTPS-Redirect + HSTS.
# Nur setzen, nachdem TLS-Terminierung auf dem Server verifiziert wurde.
# Render.com: TLS wird von Render selbst terminiert, intern laeuft HTTP.
AILIZA_FORCE_HTTPS=false

# ── Suche ─────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
AILIZA_HOST=0.0.0.0
AILIZA_PORT=8001
AILIZA_DEBUG=false

# ── Sicherheit ────────────────────────────────────────────────────────────────
# AILIZA_SECRET_KEY: Starkes zufaelliges Secret (min. 32 Zeichen). Nie committen!
# Generieren z.B. mit: python -c "import secrets; print(secrets.token_hex(32))"
AILIZA_SECRET_KEY=change-me-min-32-characters-never-commit-this
AILIZA_JWT_EXPIRY_MINUTES=60

# ── Erster Admin-User (Seed beim ersten Start) ────────────────────────────────
# Wird beim Start automatisch angelegt wenn die DB leer ist und kein User existiert.
# Danach sofort in der App ein neues Passwort setzen oder Werte entfernen!
# Mindestlaenge Passwort: 8 Zeichen.
AILIZA_ADMIN_USER=admin
AILIZA_ADMIN_PASSWORD=

# ── Wartung ───────────────────────────────────────────────────────────────────
# Wie oft der automatische Retention-Cleanup laeuft (Stunden, Default 24)
AILIZA_CLEANUP_INTERVAL_HOURS=24

# ── Messenger / Telegram ─────────────────────────────────────────────────────
# Bot-Token von @BotFather. Leer lassen wenn Telegram nicht genutzt wird.
AILIZA_TELEGRAM_BOT_TOKEN=
# Optionaler Webhook-Secret (empfohlen fuer Produktionsbetrieb)
AILIZA_TELEGRAM_WEBHOOK_SECRET=
# Max. Nachrichten pro Nutzer pro Minute (Default 10)
AILIZA_TELEGRAM_RATE_LIMIT=10

# ── Bootstrap-Sperre ─────────────────────────────────────────────────────────
# Nach create_admin.py auf true setzen — sperrt erneutes Ausfuehren des Scripts
AILIZA_SETUP_DONE=
