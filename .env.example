# AILIZA Konfiguration
# Kopiere diese Datei zu .env und fuelle die Werte aus.
# NIEMALS .env in Git committen! NIEMALS echte Keys hier eintragen!

# ── Kill-Switch (externe KI) ───────────────────────────────────────────────
# Fail-closed: Standard false. Externe LLM-Calls nur wenn true.
AILIZA_EXTERNAL_LLM_ENABLED=false

# ── Mandanten ───────────────────────────────────────────────────────────────
AILIZA_DEFAULT_TENANT_ID=default

# ── KI-Modell / Provider ────────────────────────────────────────────────────
AILIZA_MODEL=anthropic/claude-sonnet-4-6

# Provider API-Keys (mindestens einen setzen — GROQ_API_KEY empfohlen, kostenlos):
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Provider-Reihenfolge (optional, Default: groq,openai,openrouter,anthropic,local)
# Erster verfuegbarer Provider mit Key wird genutzt. Fallback automatisch.
AILIZA_PROVIDER_ORDER=groq,openai,openrouter,anthropic,local

# Optionales Modell-Override (leer = Registry-Default je Provider)
# GROQ_MODEL=llama-3.1-8b-instant
# OPENAI_MODEL=gpt-4o-mini

# ── Datenbank ────────────────────────────────────────────────────────────────
AILIZA_DB_PATH=./data/ailiza.db
AILIZA_AUDIT_DB_PATH=./data/audit.db

# ── DSGVO Einstellungen ───────────────────────────────────────────────────────
AILIZA_DATA_RETENTION_DAYS=90
AILIZA_PSEUDONYMIZE_USERS=true
AILIZA_ENCRYPT_STORAGE=true

# ── EU AI Act Einstellungen ───────────────────────────────────────────────────
AILIZA_HUMAN_OVERSIGHT=true
AILIZA_TRANSPARENCY_LANGUAGE=de
AILIZA_RISK_LEVEL=limited

# ── Server ────────────────────────────────────────────────────────────────────
AILIZA_HOST=0.0.0.0
AILIZA_PORT=8001
AILIZA_DEBUG=false

# ── Sicherheit ────────────────────────────────────────────────────────────────
# AILIZA_SECRET_KEY: Starkes zufaelliges Secret (min. 32 Zeichen). Nie committen!
# Generieren z.B. mit: python -c "import secrets; print(secrets.token_hex(32))"
AILIZA_SECRET_KEY=change-me-min-32-characters-never-commit-this
AILIZA_JWT_EXPIRY_MINUTES=60

# ── Suche ─────────────────────────────────────────────────────────────────────
# Nur fuer Suchanfragen benoetigt ("Recherchiere..."). Fuer direkte LLM-Fragen optional.
TAVILY_API_KEY=your_tavily_api_key_here

# ── Messenger / Telegram ─────────────────────────────────────────────────────
AILIZA_TELEGRAM_BOT_TOKEN=
AILIZA_TELEGRAM_WEBHOOK_SECRET=
AILIZA_TELEGRAM_RATE_LIMIT=10
